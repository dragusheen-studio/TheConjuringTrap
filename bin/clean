#!/bin/bash

# ----- CONFIGURATION -----
PROJECT_ROOT=$(cd "$(dirname "$0")/.." && pwd)
cd "$PROJECT_ROOT"

# ----- DIRECTORIES CLEANUP -----
echo ""
echo ""
echo "==========================================="
echo " CLEANING: Cleaning build directories"
echo "==========================================="
folders=("build" "build_linux" "build_windows" "dist")

for folder in "${folders[@]}"; do
    if [ -d "$folder" ]; then
        rm -rf "$folder"
    fi
done

# ----- TARGETS CLEANUP -----
echo ""
echo ""
echo "==========================================="
echo " CLEANING: Cleaning targets"
echo "==========================================="
targets=("TheConjuringTrap" "UnitTests" "TheConjuringTrap.exe" "scan_result.log")

for target in "${targets[@]}"; do
    if [ -L "$target" ] || [ -f "$target" ]; then
        rm "$target"
    fi
done

echo ""
echo ""
echo "==========================================="
echo " CLEANING: Project clean"
echo "==========================================="
