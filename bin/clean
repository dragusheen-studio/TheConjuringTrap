#!/bin/bash

# Récupération du chemin racine du projet
PROJECT_ROOT=$(cd "$(dirname "$0")/.." && pwd)
cd "$PROJECT_ROOT"

echo "--- Nettoyage du projet ---"

# Liste des dossiers à supprimer
folders=("build" "build_linux" "build_windows" "dist")

for folder in "${folders[@]}"; do
    if [ -d "$folder" ]; then
        echo "Suppression du dossier $folder/..."
        rm -rf "$folder"
    fi
done

# Liste des cibles (liens ou fichiers) à la racine
targets=("TheConjuringTrap" "UnitTests" "TheConjuringTrap.exe")

for target in "${targets[@]}"; do
    if [ -L "$target" ] || [ -f "$target" ]; then
        echo "Suppression de $target..."
        rm "$target"
    fi
done

# Suppression des logs
if [ -f "scan_result.log" ]; then
    rm "scan_result.log"
fi

echo "Projet propre."
