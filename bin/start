#!/bin/bash

# ----- CONFIGURATION -----
PROJECT_ROOT=$(cd "$(dirname "$0")/.." && pwd)
cd "$PROJECT_ROOT"

# ----- BUILD FUNCTION -----
run_project() {
	echo ""
	echo ""
	echo "==========================================="
	echo " COMPILE: Creating the directories and building the game"
	echo "==========================================="
    mkdir -p build && cd build
    cmake -DBUILD_GAME=ON -DBUILD_TESTS=OFF ..
    make -j$(nproc)
    cd ..

    if [ -f "./build/TheConjuringTrap" ]; then
        ln -sf "./build/TheConjuringTrap" "./TheConjuringTrap"
		echo ""
		echo ""
		echo "==========================================="
		echo " START: Launching the game"
		echo "==========================================="
        ./TheConjuringTrap
    else
		echo ""
		echo ""
		echo "==========================================="
		echo " ERROR: Executable not found."
		echo "==========================================="
        read -p "Press Enter to close..."
    fi
}

# ----- EXECUTION -----
gnome-terminal --tab --title="TheConjuringTrap Build" -- bash -c "$(declare -f run_project); run_project"
